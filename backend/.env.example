# ─── Base de dados ──────────────────────────────────────────
MONGODB_URI=mongodb+srv://USERNAME:PASSWORD@cluster.mongodb.net/crypto-trader

# ─── Exchange ───────────────────────────────────────────────
EXCHANGE=binance
API_KEY=a_tua_api_key
API_SECRET=o_teu_api_secret
SANDBOX=true

# ─── Trading ────────────────────────────────────────────────
SYMBOL=BTC/USDT
TIMEFRAME=1h
CHECK_INTERVAL=60
STARTING_BALANCE=10000

# ─── Gestão de risco ────────────────────────────────────────
MAX_POSITION_PCT=0.10
STOP_LOSS_PCT=0.03
TAKE_PROFIT_PCT=0.06

# ─── Servidor ───────────────────────────────────────────────
PORT=3001