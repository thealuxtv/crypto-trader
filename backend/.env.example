# ─── Exchange ───────────────────────────────────────────────
EXCHANGE=binance          # binance | kraken | coinbase
API_KEY=the_tua_api_key
API_SECRET=o_teu_api_secret
SANDBOX=true              # true = paper trading, nunca envia ordens reais

# ─── Trading ────────────────────────────────────────────────
SYMBOL=BTC/USDT           # par a negociar
TIMEFRAME=1h              # velas: 1m 5m 15m 1h 4h 1d
CHECK_INTERVAL=60         # segundos entre cada análise
STARTING_BALANCE=10000    # saldo inicial simulado em USDT

# ─── Gestão de risco ────────────────────────────────────────
MAX_POSITION_PCT=0.10     # máx 10% do saldo por trade
STOP_LOSS_PCT=0.03        # stop-loss a -3%
TAKE_PROFIT_PCT=0.06      # take-profit a +6%

# ─── Servidor ───────────────────────────────────────────────
PORT=3001
